		"/documents/upload": {
			"post": {
				"tags": ["Documents"],
				"summary": "Upload a document with optional preview images",
				"description": "\nUpload a document (PDF or image) for processing. \n\n**Important**: PDF files MUST include at least one preview image to enable visual validation.\nThis prevents text-only fake PDFs from bypassing security checks.\n\nThe endpoint will:\n1. Validate the file type and upload contract\n2. Check for duplicate documents (by SHA-256 hash)\n3. Store the document and previews in R2\n4. Create a processing job\n5. Enqueue the job for async processing\n",
				"operationId": "document-upload",
				"responses": {
					"200": {
						"description": "Duplicate document found",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": {
											"type": "boolean",
											"enum": [true]
										},
										"result": {
											"type": "object",
											"properties": {
												"documentId": {
													"type": "string"
												},
												"duplicate": {
													"type": "boolean",
													"enum": [true]
												},
												"message": {
													"type": "string"
												}
											},
											"required": ["documentId", "duplicate", "message"]
										}
									},
									"required": ["success", "result"]
								}
							}
						}
					},
					"201": {
						"description": "Document uploaded and processing job created",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": {
											"type": "boolean",
											"enum": [true]
										},
										"result": {
											"type": "object",
											"properties": {
												"documentId": {
													"type": "string"
												},
												"jobId": {
													"type": "string"
												},
												"message": {
													"type": "string"
												}
											},
											"required": ["documentId", "jobId", "message"]
										}
									},
									"required": ["success", "result"]
								}
							}
						}
					},
					"400": {
						"description": "Invalid request (missing file, invalid type, or missing preview for PDF)",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": {
											"type": "boolean",
											"enum": [false]
										},
										"error": {
											"type": "string"
										}
									},
									"required": ["success", "error"]
								}
							}
						}
					},
					"401": {
						"description": "Unauthorized",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"success": {
											"type": "boolean",
											"enum": [false]
										},
										"error": {
											"type": "string"
										}
									},
									"required": ["success", "error"]
								}
							}
						}
					}
				}
			}
		},
