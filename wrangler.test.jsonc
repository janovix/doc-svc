{
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_als"],
	"main": "src/index.ts",
	"name": "doc-svc-test",
	"upload_source_maps": true,
	"workers_dev": true,
	"version_metadata": {
		"binding": "CF_VERSION_METADATA",
	},
	"observability": {
		"enabled": true,
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "doc-test",
			"database_id": "test-database-id",
		},
	],
	// Note: Durable Objects are mocked in tests via vitest-pool-workers
	"vars": {
		"ENVIRONMENT": "test",
		"AUTH_SERVICE_URL": "https://auth-svc.test",
		"AUTH_JWKS_CACHE_TTL": "3600",
	},
}
